GAMEPANEL_DATA_DIR="./data"
GAMEPANEL_DB_PATH="./data/gamepanel.db"
GAMEPANEL_HOST="0.0.0.0"
GAMEPANEL_PORT="4000"
GAMEPANEL_DOCKER_HOST="unix:///var/run/docker.sock"
GAMEPANEL_WORKSPACE_PATH="/absolute/path/to/game-panel-lite"
GAMEPANEL_DOCKER_SOCKET_PATH="/var/run/docker.sock"
GAMEPANEL_WEB_PORT="3001"
GAMEPANEL_API_PORT="4000"
NEXT_PUBLIC_API_BASE_URL="http://localhost:4000"

GAMEPANEL_IMAGE_REGION="global"
GAMEPANEL_IMAGE_REGISTRY="smartcat99999"
GAMEPANEL_IMAGE_TAG="v0.1.0"

# China mirror example:
# GAMEPANEL_IMAGE_REGION="cn"
# GAMEPANEL_IMAGE_REGISTRY="registry.cn-hangzhou.aliyuncs.com/gamepanel-lite"

# Local OrbStack example for docker compose:
# GAMEPANEL_WORKSPACE_PATH="/Users/<you>/Desktop/Projects/go-project/game-panel-lite"
# GAMEPANEL_DOCKER_SOCKET_PATH="/Users/<you>/.orbstack/run/docker.sock"
