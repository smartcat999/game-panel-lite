{
  "name": "game-panel-lite",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "dev:api": "go run ./apps/api/cmd/server",
    "dev:web": "pnpm --filter @gamepanel-lite/web dev",
    "e2e": "playwright test",
    "lint": "eslint . --max-warnings=0",
    "test": "pnpm -r test",
    "typecheck": "pnpm -r typecheck",
    "prisma:generate": "pnpm --filter @gamepanel-lite/api prisma:generate"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^15.1.3",
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2"
  }
}
